{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "app.py"
    }
  ],
  "functions": {
    "app.py": {
      "includeFiles": "{archives/**,logs/**,public/**,rates/**,secret_vault_713/**,tmp/**}"
    }
  }
}